# ── Formspree ─────────────────────────────────────────────────────────────────
# 1. Create a free form at https://formspree.io
# 2. Copy the form ID from the form URL (e.g. "xpwzabcd" from formspree.io/f/xpwzabcd)
# 3. Paste it below, then copy this file to .env and fill in your values
VITE_FORMSPREE_ID=your_formspree_form_id

# ── Analytics (optional) ───────────────────────────────────────────────────────
# VITE_GA_ID=G-XXXXXXXXXX
